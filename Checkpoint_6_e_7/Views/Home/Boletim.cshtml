@{
    ViewData["Title"] = "Boletim";

    var disciplinas = (List<string>)ViewBag.Disciplinas!;
    var notas = (List<double>)ViewBag.Notas!;

    double soma = 0;
}

<h2>Boletim de Notas</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Disciplina</th>
            <th>Nota</th>
            <th>Status</th>
            <th>Conceito</th>
        </tr>
    </thead>
    <tbody>
        @for (int i = 0; i < disciplinas.Count; i++)
        {
            soma += notas[i];

            <tr>
                <td>@disciplinas[i]</td>
                <td>@notas[i]</td>

                <td>
                    @if (notas[i] >= 6)
                    {
                        <span style="color:green;">Aprovado</span>
                    }
                    else
                    {
                        <span style="color:red;">Reprovado</span>
                    }
                </td>

                <td>
                    @{
                        string conceito = "";

                        switch (notas[i])
                        {
                            case >= 9:
                                conceito = "A";
                                break;

                            case >= 7:
                                conceito = "B";
                                break;

                            case >= 5:
                                conceito = "C";
                                break;

                            default:
                                conceito = "D";
                                break;
                        }
                    }

                    @conceito
                </td>
            </tr>
        }
    </tbody>
</table>

<p>
    <strong>Média Geral: @(soma / notas.Count).ToString("F2")</strong>
</p>